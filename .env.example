# CityRisk Scout — Environment Variables
# Copy this file to .env and fill in your values

# -------------------------------------------------------
# LLM Provider: "anthropic" or "openai" (default)
# -------------------------------------------------------
LLM_PROVIDER=openai

# -------------------------------------------------------
# Anthropic (used when LLM_PROVIDER=anthropic)
# -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# -------------------------------------------------------
# OpenAI-compatible (used when LLM_PROVIDER=openai)
# Works with: LM Studio, Ollama, vLLM, Together AI, OpenRouter, Groq
#
# LM Studio quick-start:
#   1. Open LM Studio → load any instruct model
#   2. Start the local server (default port 1234)
#   3. Copy the model identifier from the server tab
#   4. Set the three vars below
# -------------------------------------------------------
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=mistral-7b-instruct-v0.3  # replace with your loaded model name
OPENAI_API_KEY=lm-studio               # LM Studio ignores this value, but it must be set
OPENAI_MAX_TOKENS=1500

# -------------------------------------------------------
# Token / prompt size controls
# Tune these when hitting rate-limit 413 errors.
# -------------------------------------------------------

# Max signals forwarded to the LLM per request.
# Lower to 10-15 for models with tight context windows (e.g. Groq free tier).
MAX_SIGNALS=20

# Hard character budget for the assembled user message (~4 chars per token).
# Default 12000 chars ≈ 3000 tokens — safe under a 6000-TPM limit.
# Raise to 20000+ for local models or APIs with no token cap.
MAX_PROMPT_CHARS=12000
