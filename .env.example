# CityRisk Scout — Environment Variables
# Copy this file to .env and fill in your values

# -------------------------------------------------------
# LLM Provider: "anthropic" (default) or "openai"
# -------------------------------------------------------
LLM_PROVIDER=anthropic

# -------------------------------------------------------
# Anthropic (used when LLM_PROVIDER=anthropic)
# -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# -------------------------------------------------------
# OpenAI-compatible (used when LLM_PROVIDER=openai)
# Works with: LM Studio, Ollama, vLLM, Together AI, OpenRouter
#
# LM Studio quick-start:
#   1. Open LM Studio → load any instruct model
#   2. Start the local server (default port 1234)
#   3. Copy the model identifier from the server tab
#   4. Set the three vars below
# -------------------------------------------------------
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=mistral-7b-instruct-v0.3  # replace with your loaded model name
OPENAI_API_KEY=lm-studio               # LM Studio ignores this value, but it must be set
OPENAI_MAX_TOKENS=2048

# -------------------------------------------------------
# Shared
# -------------------------------------------------------
# Max signals forwarded to the LLM per request.
# Reduce to 20-25 for small context window local models (e.g. 4k ctx).
MAX_SIGNALS=40
